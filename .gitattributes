* text=auto eol=lf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Keep GitHub language stats focused on this package, not bundled MediaWiki.
vendor/mediawiki-1.39.3/** linguist-vendored
dist/** linguist-generated=true

