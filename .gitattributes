node_modules/** export-ignore
.ja-ucp-preview-work/** export-ignore
tmp/** export-ignore
vendor/downloads/** export-ignore
*.tgz export-ignore
*.tar export-ignore
*.tar.gz export-ignore
*.zip export-ignore
