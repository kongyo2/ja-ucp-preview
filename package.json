{
  "name": "@kongyo2/ja-ucp-preview",
  "version": "0.1.0",
  "description": "Exact-only offline Japanese Uncyclopedia preview renderer target for TypeScript/Node.js.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/php",
    "vendor/mediawiki-1.39.3",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "test": "vitest run test/render.test.ts",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "mediawiki",
    "uncyclopedia",
    "wikitext",
    "preview",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@php-wasm/node": "^3.1.20",
    "@php-wasm/universal": "^3.1.20"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
