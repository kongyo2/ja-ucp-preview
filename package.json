{
  "name": "@kongyo2/ja-ucp-preview",
  "version": "0.1.3",
  "description": "Offline Japanese Uncyclopedia preview renderer for TypeScript/Node.js. Bundles MediaWiki 1.39.3 + the parser-affecting Japanese Uncyclopedia extensions and runs them under PHP/WASM (no system PHP required).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/php",
    "vendor/mediawiki-1.39.3",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "test": "vitest run test/render.test.ts",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "mediawiki",
    "uncyclopedia",
    "wikitext",
    "preview",
    "typescript",
    "ja-ucp",
    "ansaikuropedia"
  ],
  "author": "kongyo2",
  "license": "MIT",
  "homepage": "https://github.com/kongyo2/ja-ucp-preview#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kongyo2/ja-ucp-preview.git"
  },
  "bugs": {
    "url": "https://github.com/kongyo2/ja-ucp-preview/issues"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@php-wasm/node": "^3.1.20",
    "@php-wasm/universal": "^3.1.20",
    "@php-wasm/util": "^3.1.20",
    "wasmoon-lua5.1": "^1.18.10"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
